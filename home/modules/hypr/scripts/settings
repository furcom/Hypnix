###################################################
#################### Variables ####################
###################################################

# Monitor
MONITOR=$(hyprctl monitors | grep Monitor | awk '{print $2}')

# General
EDITOR="vim"
TERMINAL="kitty"

RofiScriptsDir="$RofiDir/scripts"
RofiMenu="rofi -dmenu -config $RofiDir/config.rasi"
RofiMenuSettings="rofi -dmenu"

###################################################
#################### Functions ####################
###################################################

main_menu() {
  OPTIONS="ÓČĶ Hyprland\nůįŹĖ Packages\nÔÄÖ Extras\nůįłČ Wallpaper\nůįÖô Exit"
  CHOICE=$(echo -e "$OPTIONS" | $RofiMenuSettings -selected-row $SelectedRowMain -theme-str 'inputbar{enabled:false;} window{height:12.125em;width:9em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$CHOICE" ]; then
    exit 0
  fi

  if [ -z "$CHOICE" ]; then
    main_menu
  elif [ "$CHOICE" == "ůįÖô Exit" ]; then
    exit 0
  else
    case "$CHOICE" in
      "ÓČĶ Hyprland")
        hyprland_menu ;;
      "ůįłČ Wallpaper")
        waypaper ;;
      "ÔÄÖ Extras")
        extras_menu ;;
      "ůįŹĖ Packages")
        packages_menu ;;
      *)
        echo "Invalid choice" ;;
    esac
  fi
}

hyprland_menu() {
  HYPRLAND_OPTIONS="ůį§ļ Animations\nÔĄú Bindings\nÓąę Colors (Wallust)\nůįąô Config\nÓ≠£ Decorations\nÓėē General\nůįćĹ Input\nÓĮę Layouts\nÓöź Misc\nÔíá Plugins\nÓäč Rules\nůĪě≤ Back"
  HYPRLAND_SUBCHOICE=$(echo -e "$HYPRLAND_OPTIONS" | $RofiMenuSettings -selected-row $SelectedRowHypr -theme-str 'inputbar{enabled:false;} window{height:26.125em;width:12.5em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$HYPRLAND_SUBCHOICE" ]; then
    SelectedRowMain="0"
	  main_menu
      elif [ "$HYPRLAND_SUBCHOICE" == "ůĪě≤ Back" ]; then
        SelectedRowMain="0"
        main_menu
      else
      case "$HYPRLAND_SUBCHOICE" in
        "ůį§ļ Animations") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/animations.nix" ;;
        "ÔĄú Bindings") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/bind.nix" ;;
        "Óąę Colors (Wallust)") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/hyprland";;
        "ůįąô Config") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/hyprland.nix" ;;
        "Ó≠£ Decorations") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules//hypr/configs/decorations.nix" ;;
        "Óėē General") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/general.nix" ;;
        "ůįćĹ Input") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/input.nix" ;;
        "ÓĮę Layouts") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/layouts.nix" ;;
        "Óöź Misc") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/misc.nix" ;;
        "Ôíá Plugins")$TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/plugins.nix" ;;
        "Óäč Rules") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/hypr/configs/rules.nix" ;;
      esac
  fi
}

packages_menu() {
  PACKAGES_OPTIONS="ůįŹē Update Nix Packages\nÓóľ Flake Rebuild System\nůįÉĘ Nix Garbage Collect\nůĪě≤ Back"
  PACKAGES_SUBCHOICE=$(echo -e "$PACKAGES_OPTIONS" | $RofiMenuSettings -theme-str 'inputbar{enabled:false;} window{height:10.25em;width:14.75em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$PACKAGES_SUBCHOICE" ]; then
 ~/hypnix/home/configs/wallust/templates   SelectedRowMain="1"
    main_menu
  elif [ "$PACKAGES_SUBCHOICE" == "ůĪě≤ Back" ]; then
    SelectedRowMain="1"
    main_menu
  else
    case "$PACKAGES_SUBCHOICE" in
      "ůįŹē Update Nix Packages") $TERMINAL sh -c "~/hypnix/home/modules/hypr/scripts/settings --update-nix-pkgs" ;;
      "Óóľ Flake Rebuild System") $TERMINAL sh -c "~/hypnix/home/modules/hypr/scripts/settings --flake-rebuild-sys" ;;
      "ůįÉĘ Nix Garbage Collect") $TERMINAL sh -c "~/hypnix/home/modules/hypr/scripts/settings --nix-garbage-collect" ;;
    esac
  fi
}

extras_menu() {
  EXTRAS_OPTIONS="ůįĶ∑ Fusuma\nÔÄ£ Hyprlock\nůĪā© HyprPanel\nůįĄõ Kitty\nÔĄ† Oh My Posh\nůįģę Rofi\nÓąę Wallust\nůĪě≤ Back"
  EXTRAS_SUBCHOICE=$(echo -e "$EXTRAS_OPTIONS" | $RofiMenuSettings -selected-row $SelectedRowExtras -theme-str 'inputbar{enabled:false;} window{height:18em;width:9.5em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$EXTRAS_SUBCHOICE" ]; then
    SelectedRowMain="2"
    main_menu
  elif [ "$EXTRAS_SUBCHOICE" == "ůĪě≤ Back" ]; then
    SelectedRowMain="2"
    main_menu
  else
    case "$EXTRAS_SUBCHOICE" in
      "ůįĶ∑ Fusuma") fusuma_menu ;;
      "ÔÄ£ Hyprlock") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/hyprlock" ;;
      "ůĪā© HyprPanel") hyprpanel_menu ;;
      "ůįĄõ Kitty") kitty_menu ;;
      "ÔĄ† Oh My Posh") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/oh-my-posh" ;;
      "ůįģę Rofi") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/rofi" ;;
      "Óąę Wallust") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/wallust.toml" ;;
    esac
  fi
}

fusuma_menu() {
  FUSUMA_OPTIONS="ůįąô Config\nůįĎď Restart\nůĪě≤ Back"
  FUSUMA_SUBCHOICE=$(echo -e "$FUSUMA_OPTIONS" | $RofiMenuSettings -theme-str 'inputbar{enabled:false;} window{height:8.25em;width:8em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$FUSUMA_SUBCHOICE" ]; then
    SelectedRowExtras="0"
    extras_menu
  elif [ "$FUSUMA_SUBCHOICE" == "ůĪě≤ Back" ]; then
    SelectedRowExtras="0"
    extras_menu
  else
    case "$FUSUMA_SUBCHOICE" in
      "ůįąô Config") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/fusuma.nix" ;;
      "ůįĎď Restart") pkill fusuma && fusuma -d ;;
    esac
  fi
}

hyprpanel_menu() {
  HYPRPANEL_OPTIONS="ůįąô Config\nůįĎď Restart\nůĪě≤ Back"
  HYPRPANEL_SUBCHOICE=$(echo -e "$HYPRPANEL_OPTIONS" | $RofiMenuSettings -theme-str 'inputbar{enabled:false;} window{height:8.25em;width:8em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$HYPRPANEL_SUBCHOICE" ]; then
    SelectedRowExtras="2"
    extras_menu
  elif [ "$HYPRPANEL_SUBCHOICE" == "ůĪě≤ Back" ]; then
    SelectedRowExtras="2"
    extras_menu
  else
    case "$HYPRPANEL_SUBCHOICE" in
      "ůįĎď Restart") hyprpanel -q; hyprpanel ;;
      "ůįąô Config" ) $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/hyprpanel" ;;
    esac
  fi
}

kitty_menu() {
  KITTY_OPTIONS="ůįąô Config\nůįĎď Reload Config\nÓąę Colors (Wallust)\nůĪě≤ Back"
  KITTY_SUBCHOICE=$(echo -e "$KITTY_OPTIONS" | $RofiMenuSettings -theme-str 'inputbar{enabled:false;} window{height:10.25em;width:12.5em;} listview{scrollbar:false;} configuration{show-icons:false;}')

  if [ -z "$KITTY_SUBCHOICE" ]; then
    SelectedRowExtras="3"
    extras_menu
  elif [ "$KITTY_SUBCHOICE" == "ůĪě≤ Back" ]; then
    SelectedRowExtras="3"
    extras_menu
  else
    case "$KITTY_SUBCHOICE" in
      "ůįąô Config") $TERMINAL sh -c "$EDITOR ~/hypnix/home/modules/kitty.nix" ;;
      "ůįĎď Reload Config") kill -SIGUSR1 $(pidof kitty) ;;
      "Óąę Colors (Wallust)") $TERMINAL sh -c "$EDITOR ~/hypnix/home/files/wallust/templates/kitty" ;;
    esac
  fi
}

#####################################################
#################### Main Script ####################
#####################################################

# Process script arguments
case "$1" in
 --menu) main_menu ;;
  --uno) update_nix_pakages ;;
  --frs) flake_rebuild_system ;;
  --ngc) nix_garbage_collect ;;
      *) exit 1 ;;
esac
