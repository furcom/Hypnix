#hibernate { background-image: image(url("/home/furcom/hypnix/home/.config/wlogout/img/hibernate.png"), url("/home/furcom/hypnix/home/.config/wlogout/img/hibernate.png")); }

#poweroff { background-image: image(url("/home/furcom/hypnix/home/.config/wlogout/img/poweroff.png"), url("/home/furcom/hypnix/home/.config/wlogout/img/poweroff.png")); }

#reboot { background-image: image(url("/home/furcom/hypnix/home/.config/wlogout/img/reboot.png"), url("/home/furcom/hypnix/home/.config/wlogout/img/reboot.png")); }
